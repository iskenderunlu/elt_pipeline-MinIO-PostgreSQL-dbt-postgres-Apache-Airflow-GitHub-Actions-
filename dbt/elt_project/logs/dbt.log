  create  table "dwh"."staging_marts"."fct_orders__dbt_tmp"
  
  
    as
  
  (
    -- Fact tablosu: sipariş + müşteri + ürün birleşimi
-- Analitik sorgular buradan çalışır.



SELECT
    o.order_id,
    o.order_date,
    DATE_TRUNC('month', o.order_date)   AS order_month,
    DATE_TRUNC('week',  o.order_date)   AS order_week,

    -- Müşteri bilgileri
    o.customer_id,
    c.customer_name,
    c.city                              AS customer_city,
    c.country_code,

    -- Ürün bilgileri
    o.product_id,
    p.product_name,
    p.category                          AS product_category,
    p.unit_price,

    -- Sipariş metrikleri
    o.quantity,
    o.amount_usd,
    o.amount_usd / NULLIF(o.quantity, 0)   AS avg_unit_price,
    o.status,

    -- İş metrikleri
    CASE WHEN o.status = 'DELIVERED' THEN o.amount_usd ELSE 0 END AS revenue,
    CASE WHEN o.status = 'CANCELLED' THEN 1 ELSE 0 END            AS is_cancelled,

    o.loaded_at

FROM "dwh"."staging_staging"."stg_orders"    o
LEFT JOIN "dwh"."staging_staging"."stg_customers" c USING (customer_id)
LEFT JOIN "dwh"."staging_staging"."stg_products"  p USING (product_id)
  );
  
[0m10:58:22.484605 [debug] [Thread-4 (]: SQL status: BEGIN in 0.025 seconds
[0m10:58:22.486421 [debug] [Thread-4 (]: Using postgres connection "model.elt_project.dim_customers"
[0m10:58:22.488803 [debug] [Thread-4 (]: On model.elt_project.dim_customers: /* {"app": "dbt", "dbt_version": "1.8.9", "profile_name": "elt_project", "target_name": "dev", "node_id": "model.elt_project.dim_customers"} */

  
    

  create  table "dwh"."staging_marts"."dim_customers__dbt_tmp"
  
  
    as
  
  (
    -- Boyut tablosu: müşteri segmentasyonu ve özet metrikler



WITH order_summary AS (
    SELECT
        customer_id,
        COUNT(*)                            AS total_orders,
        SUM(amount_usd)                     AS total_spent,
        MAX(order_date)                     AS last_order_date,
        MIN(order_date)                     AS first_order_date,
        SUM(CASE WHEN status = 'DELIVERED'
                 THEN amount_usd ELSE 0 END) AS delivered_revenue
    FROM "dwh"."staging_staging"."stg_orders"
    GROUP BY customer_id
)

SELECT
    c.customer_id,
    c.customer_name,
    c.email,
    c.city,
    c.country_code,
    c.signup_date,

    -- Order metrikleri
    COALESCE(os.total_orders, 0)        AS total_orders,
    COALESCE(os.total_spent, 0)         AS total_spent_usd,
    COALESCE(os.delivered_revenue, 0)   AS delivered_revenue_usd,
    os.first_order_date,
    os.last_order_date,

    -- Segment
    CASE
        WHEN COALESCE(os.total_spent, 0) >= 10000 THEN 'VIP'
        WHEN COALESCE(os.total_spent, 0) >= 3000  THEN 'Regular'
        ELSE 'New'
    END AS customer_segment

FROM "dwh"."staging_staging"."stg_customers" c
LEFT JOIN order_summary os USING (customer_id)
  );
  
