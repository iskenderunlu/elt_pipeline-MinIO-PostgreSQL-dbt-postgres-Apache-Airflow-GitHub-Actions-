d_code": "\n    \n    \n\n\n\nselect quantity\nfrom \"dwh\".\"staging\".\"stg_orders\"\nwhere quantity is null\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.639720Z", "completed_at": "2026-06-25T11:16:05.664271Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.668517Z", "completed_at": "2026-06-25T11:16:05.668526Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.04181337356567383, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.not_null_stg_orders_order_id.81cfe2fe64", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect order_id\nfrom \"dwh\".\"staging\".\"stg_orders\"\nwhere order_id is null\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.669868Z", "completed_at": "2026-06-25T11:16:05.686079Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.697326Z", "completed_at": "2026-06-25T11:16:05.697341Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.036139726638793945, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.not_null_stg_orders_status.2b01eecbd6", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect status\nfrom \"dwh\".\"staging\".\"stg_orders\"\nwhere status is null\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.698893Z", "completed_at": "2026-06-25T11:16:05.710572Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.720827Z", "completed_at": "2026-06-25T11:16:05.720843Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.03958845138549805, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.elt_project.fct_orders", "compiled": true, "compiled_code": "-- Fact tablosu: sipari\u015f + m\u00fc\u015fteri + \u00fcr\u00fcn birle\u015fimi\n-- Analitik sorgular buradan \u00e7al\u0131\u015f\u0131r.\n\n\n\nSELECT\n    o.order_id,\n    o.order_date,\n    DATE_TRUNC('month', o.order_date)   AS order_month,\n    DATE_TRUNC('week',  o.order_date)   AS order_week,\n\n    -- M\u00fc\u015fteri bilgileri\n    o.customer_id,\n    c.customer_name,\n    c.city                              AS customer_city,\n    c.country_code,\n\n    -- \u00dcr\u00fcn bilgileri\n    o.product_id,\n    p.product_name,\n    p.category                          AS product_category,\n    p.unit_price,\n\n    -- Sipari\u015f metrikleri\n    o.quantity,\n    o.amount_usd,\n    o.amount_usd / NULLIF(o.quantity, 0)   AS avg_unit_price,\n    o.status,\n\n    -- \u0130\u015f metrikleri\n    CASE WHEN o.status = 'DELIVERED' THEN o.amount_usd ELSE 0 END AS revenue,\n    CASE WHEN o.status = 'CANCELLED' THEN 1 ELSE 0 END            AS is_cancelled,\n\n    o.loaded_at\n\nFROM \"dwh\".\"staging\".\"stg_orders\"    o\nLEFT JOIN \"dwh\".\"staging\".\"stg_customers\" c USING (customer_id)\nLEFT JOIN \"dwh\".\"staging\".\"stg_products\"  p USING (product_id)", "relation_name": "\"dwh\".\"marts\".\"fct_orders\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.687072Z", "completed_at": "2026-06-25T11:16:05.706582Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.713213Z", "completed_at": "2026-06-25T11:16:05.713223Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.035219430923461914, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.unique_stg_orders_order_id.e3b841c71a", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    order_id as unique_field,\n    count(*) as n_records\n\nfrom \"dwh\".\"staging\".\"stg_orders\"\nwhere order_id is not null\ngroup by order_id\nhaving count(*) > 1\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.692262Z", "completed_at": "2026-06-25T11:16:05.707358Z"}, {"name": "execute", "s