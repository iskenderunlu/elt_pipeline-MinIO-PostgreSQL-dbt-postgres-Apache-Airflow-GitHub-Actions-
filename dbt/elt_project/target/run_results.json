er_id::VARCHAR(20)            AS customer_id,\n    order_date::DATE                    AS order_date,\n    UPPER(TRIM(status))::VARCHAR(20)    AS status,\n    amount::NUMERIC(12,2)               AS amount_usd,\n    product_id::VARCHAR(20)             AS product_id,\n    quantity::INTEGER                   AS quantity,\n    _loaded_at                          AS loaded_at\n\nFROM \"dwh\".\"raw\".\"orders\"\n\nWHERE\n    order_id    IS NOT NULL\n    AND amount  IS NOT NULL\n    AND amount::NUMERIC > 0", "relation_name": "\"dwh\".\"staging\".\"stg_orders\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.476973Z", "completed_at": "2026-06-25T11:16:05.487752Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.492740Z", "completed_at": "2026-06-25T11:16:05.492765Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.03327059745788574, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.elt_project.stg_products", "compiled": true, "compiled_code": "\n\nSELECT\n    product_id::VARCHAR(20)             AS product_id,\n    TRIM(product_name)                  AS product_name,\n    INITCAP(TRIM(category))             AS category,\n    unit_price::NUMERIC(12,2)           AS unit_price\n\nFROM \"dwh\".\"raw\".\"products\"\n\nWHERE product_id IS NOT NULL", "relation_name": "\"dwh\".\"staging\".\"stg_products\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.506952Z", "completed_at": "2026-06-25T11:16:05.552528Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.555773Z", "completed_at": "2026-06-25T11:16:05.555788Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.05950164794921875, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.not_null_stg_customers_customer_id.e2cfb1f9aa", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect customer_id\nfrom \"dwh\".\"staging\".\"stg_customers\"\nwhere customer_id is null\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.527209Z", "completed_at": "2026-06-25T11:16:05.554132Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.559312Z", "completed_at": "2026-06-25T11:16:05.559328Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.06162619590759277, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.not_null_stg_customers_email.d7cf761533", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect email\nfrom \"dwh\".\"staging\".\"stg_customers\"\nwhere email is null\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.546708Z", "completed_at": "2026-06-25T11:16:05.560531Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.565540Z", "completed_at": "2026-06-25T11:16:05.565553Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.06121706962585449, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.unique_stg_customers_customer_id.c7614daada", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    customer_id as unique_field,\n    count(*) as n_records\n\nfrom \"dwh\".\"staging\".\"stg_customers\"\nwhere customer_id is not null\ngroup by customer_id\nhaving count(*) > 1\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.534910Z", "completed_at": "2026-06-25T11:16:05.557771Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.567046Z", "completed_at": "2026-06-25T11:16:05.567059Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.06682586669921875, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.unique_stg_customers_email.1ebcb2333e", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    email as unique_field,\n    count(*) as n_records\n\nfrom \"dwh\".\"staging\".\"stg_customers\"\nwhere email is not null\ngroup by email\nhaving count(*) > 1\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.569772Z", "completed_at": "2026-06-25T11:16:05.597592Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.604683Z", "completed_at": "2026-06-25T11:16:05.604694Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.041838884353637695, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.elt_project.dim_customers", "compiled": true, "compiled_code": "-- Boyut tablosu: m\u00fc\u015fteri segmentasyonu ve \u00f6zet metrikler\n\n\n\nWITH order_summary AS (\n    SELECT\n        customer_id,\n        COUNT(*)                            AS total_orders,\n        SUM(amount_usd)                     AS total_spent,\n        MAX(order_date)                     AS last_order_date,\n        MIN(order_date)                     AS first_order_date,\n        SUM(CASE WHEN status = 'DELIVERED'\n                 THEN amount_usd ELSE 0 END) AS delivered_revenue\n    FROM \"dwh\".\"staging\".\"stg_orders\"\n    GROUP BY customer_id\n)\n\nSELECT\n    c.customer_id,\n    c.customer_name,\n    c.email,\n    c.city,\n    c.country_code,\n    c.signup_date,\n\n    -- Order metrikleri\n    COALESCE(os.total_orders, 0)        AS total_orders,\n    COALESCE(os.total_spent, 0)         AS total_spent_usd,\n    COALESCE(os.delivered_revenue, 0)   AS delivered_revenue_usd,\n    os.first_order_date,\n    os.last_order_date,\n\n    -- Segment\n    CASE\n        WHEN COALESCE(os.total_spent, 0) >= 10000 THEN 'VIP'\n        WHEN COALESCE(os.total_spent, 0) >= 3000  THEN 'Regular'\n        ELSE 'New'\n    END AS customer_segment\n\nFROM \"dwh\".\"staging\".\"stg_customers\" c\nLEFT JOIN order_summary os USING (customer_id)", "relation_name": "\"dwh\".\"marts\".\"dim_customers\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.582749Z", "completed_at": "2026-06-25T11:16:05.604068Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.612500Z", "completed_at": "2026-06-25T11:16:05.612515Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.034888267517089844, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.accepted_values_stg_orders_status__PENDING__SHIPPED__DELIVERED__CANCELLED.46d528b940", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        status as value_field,\n        count(*) as n_records\n\n    from \"dwh\".\"staging\".\"stg_orders\"\n    group by status\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'PENDING','SHIPPED','DELIVERED','CANCELLED'\n)\n\n\n", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.600042Z", "completed_at": "2026-06-25T11:16:05.614847Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.619929Z", "completed_at": "2026-06-25T11:16:05.619941Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.0400393009185791, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt_project.assert_no_future_orders", "compiled": true, "compiled_code": "-- \u00d6zel test: gelecek tarihli sipari\u015f olmamal\u0131\n-- Bu test s\u0131f\u0131r sat\u0131r d\u00f6nd\u00fcrmeli (s\u0131f\u0131r = test ge\u00e7ti)\n\nSELECT order_id, order_date\nFROM \"dwh\".\"staging\".\"stg_orders\"\nWHERE order_date > CURRENT_DATE", "relation_name": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-25T11:16:05.606131Z", "completed_at": "2026-06-25T11:16:05.619040Z"}, {"name": "execute", "started_at": "2026-06-25T11:16:05.624088Z", "completed_at": "2026-06-25T11:16:05.624108Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.043175697326660156, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.elt